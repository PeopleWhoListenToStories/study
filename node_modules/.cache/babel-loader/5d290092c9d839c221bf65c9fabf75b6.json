AA,IAAA,EAAA,MADA;AAEA,IAAA,cAAA,EAAA,IAFA;AAEA;AACA,IAAA,IAAA,EAAA,OAAA,EAHA;AAIA,IAAA,GAAA,EAAA,CAJA;AAKA,IAAA,MAAA,EAAA,CALA;AAMA,IAAA,IAAA,EAAA,CANA;AAOA,IAAA,KAAA,EAAA,CAPA;AAQA,IAAA,MAAA,EAAA,QARA;AASA,IAAA,WAAA,EAAA,EATA;AAUA,IAAA,uBAAA,EAAA,GAVA;AAWA,IAAA,iBAAA,EAAA,IAXA;AAWA;AACA,IAAA,gBAAA,EAAA,CAZA;AAaA,IAAA,SAAA,EAAA,IAbA;AAcA,IAAA,IAAA,EAAA,IAdA;AAcA;AACA,IAAA,MAAA,EAAA,QAfA;AAeA;AACA,IAAA,UAAA,EAAA,EAhBA;AAgBA;AACA,IAAA,kBAAA,EAAA,IAjBA;AAkBA,IAAA,SAAA,EAAA;AACA,MAAA,WAAA,EAAA;AADA,KAlBA;AAqBA,IAAA,KAAA,EAAA;AACA;AACA,MAAA,KAAA,EAAA,MAFA;AAGA,MAAA,QAAA,EAAA,EAHA;AAIA,MAAA,UAAA,EAAA,iBAJA;AAKA,MAAA,QAAA,EAAA,QALA;AAMA,MAAA,MAAA,EAAA;AANA,KArBA;AA6BA,IAAA,SAAA,EAAA;AACA,MAAA,MAAA,EAAA;AACA,QAAA,KAAA,EAAA,CADA;AAEA;AACA,QAAA,IAAA,EAAA;AAHA;AADA;AA7BA,GADA;AA/BA,CAAA;AAuEA,eAAA;AACA,EAAA,OADA,qBACA;AACA,SAAA,IAAA;AACA,GAHA;AAIA,EAAA,OAAA,EAAA;AACA,IAAA,IADA,kBACA;AACA,UAAA,QAAA,GAAA,KAAA,KAAA,CAAA,QAAA;AACA,UAAA,OAAA,GAAA,OAAA,CAAA,IAAA,CAAA,QAAA,EAAA,MAAA,CAAA;AACA,MAAA,OAAA,CAAA,SAAA,CAAA,MAAA;AACA,MAAA,OAAA,CAAA,EAAA,CAAA,WAAA,EAAA,UAAA,MAAA,EAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,cAAA,EAAA,MAAA;AACA,OAFA,EAJA,CAQA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA,MAAA,OAAA,CAAA,EAAA,CAAA,SAAA,EAAA,UAAA,MAAA,EAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,YAAA;AACA,OAFA;AAGA,MAAA,OAAA,CAAA,GAAA,CAAA,OAAA,CAAA,UAAA;AACA;AAtBA;AAJA,CAAA","sourcesContent":["<template>\r\n  <div ref=\"chartDom\" class=\"chart\"></div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts'\r\n// 采用关系图实现的版本地址，欢迎前往查看，效果比此图更好，谢谢\r\n// https://gallery.echartsjs.com/editor.html?c=xO6bpzhc_c\r\n\r\nvar colors = [\r\n  '#00ADD0',\r\n  '#FFA12F',\r\n  '#B62AFF',\r\n  '#604BFF',\r\n  '#6E35FF',\r\n  '#002AFF',\r\n  '#20C0F4',\r\n  '#95F300',\r\n  '#04FDB8',\r\n  '#AF5AFF'\r\n]\r\nvar getdata = function getData() {\r\n  let data = {\r\n    name: '根节点1',\r\n    value: 0,\r\n    children: []\r\n  }\r\n  for (let i = 1; i <= 10; i++) {\r\n    let obj = {\r\n      name: '节点' + i,\r\n      value: i,\r\n      children: []\r\n    }\r\n    for (let j = 1; j <= 5; j++) {\r\n      let obj2 = {\r\n        name: `节点1-${i}-${j}`,\r\n        value: 1 + '-' + i + '-' + j\r\n      }\r\n      if (j % 2 == 1) {\r\n        obj2.children = []\r\n        for (let k = 1; k <= 3; k++) {\r\n          let obj3 = {\r\n            name: `节点1-${i}-${j}-${k}`,\r\n            value: 1 + '-' + i + '-' + j + '-' + k\r\n          }\r\n          obj2.children.push(obj3)\r\n        }\r\n      }\r\n\r\n      obj.children.push(obj2)\r\n    }\r\n\r\n    data.children.push(obj)\r\n  }\r\n  let arr = []\r\n  arr.push(data)\r\n  console.log(arr)\r\n  //\r\n  arr = handle(arr, 0)\r\n  console.log(arr)\r\n  return arr\r\n}\r\nvar handle = function handleData(data, index, color = '#00f6ff') {\r\n  //index标识第几层\r\n  return data.map((item, index2) => {\r\n    //计算出颜色\r\n    if (index == 1) {\r\n      color = colors.find((item, eq) => eq == index2 % 10)\r\n    }\r\n    // 设置节点大小\r\n    if (index === 0 || index === 1) {\r\n      item.label = {\r\n        position: 'inside'\r\n        //   rotate: 0,\r\n        //   borderRadius: \"50%\",\r\n      }\r\n    }\r\n    // 设置label大小\r\n    switch (index) {\r\n      case 0:\r\n        item.symbolSize = 70\r\n        break\r\n      case 1:\r\n        item.symbolSize = 50\r\n        break\r\n      default:\r\n        item.symbolSize = 30\r\n        break\r\n    }\r\n    // 设置线条颜色\r\n    item.lineStyle = { color: color }\r\n\r\n    if (item.children) {\r\n      //存在子节点\r\n      item.itemStyle = {\r\n        borderColor: color,\r\n        color: color\r\n      }\r\n      item.children = handle(item.children, index + 1, color)\r\n    } else {\r\n      //不存在\r\n      item.itemStyle = {\r\n        color: 'transparent',\r\n        borderColor: color\r\n      }\r\n    }\r\n    return item\r\n  })\r\n}\r\n\r\nvar option = {\r\n  type: 'tree',\r\n  backgroundColor: '#000',\r\n  // 工具栏\r\n  toolbox: {\r\n    show: true,\r\n    left: 'right',\r\n    right: 20,\r\n    top: 'bottom',\r\n    bottom: 20\r\n  },\r\n  tooltip: {\r\n    //提示框\r\n    trigger: 'item',\r\n    triggerOn: 'mousemove',\r\n    backgroundColor: 'rgba(1,70,86,1)',\r\n    borderColor: 'rgba(0,246,255,1)',\r\n    borderWidth: 0.5,\r\n    textStyle: {\r\n      fontSize: 10\r\n    }\r\n    // formatter: function (params) {\r\n    //   return (\r\n    //     'X: ' +\r\n    //     params.data.symbolSize +\r\n    //     // params.event.event.offsetX +\r\n    //     '<br>Y: '\r\n    //     // params.event.event.offsetY\r\n    //   )\r\n    // }\r\n  },\r\n  series: [\r\n    {\r\n      type: 'tree',\r\n      hoverAnimation: true, //hover样式\r\n      data: getdata(),\r\n      top: 0,\r\n      bottom: 0,\r\n      left: 0,\r\n      right: 0,\r\n      layout: 'radial',\r\n      nodePadding: 20,\r\n      animationDurationUpdate: 750,\r\n      expandAndCollapse: true, //子树折叠和展开的交互，默认打开\r\n      initialTreeDepth: 2,\r\n      draggable: true,\r\n      roam: true, //是否开启鼠标缩放和平移漫游。scale/move/true\r\n      symbol: 'circle', //线两端的标记类型\r\n      symbolSize: 10, //线两端的标记大小\r\n      focusNodeAdjacency: true,\r\n      itemStyle: {\r\n        borderWidth: 1\r\n      },\r\n      label: {\r\n        //标签样式\r\n        color: '#fff',\r\n        fontSize: 10,\r\n        fontFamily: 'SourceHanSansCN',\r\n        position: 'inside',\r\n        rotate: 0\r\n      },\r\n      lineStyle: {\r\n        normal:{\r\n          width: 1,\r\n          // curveness: 0.5,\r\n          type: 'line'\r\n        }\r\n      }\r\n    }\r\n  ]\r\n}\r\nexport default {\r\n  mounted() {\r\n    this.init()\r\n  },\r\n  methods: {\r\n    init() {\r\n      var chartDom = this.$refs.chartDom\r\n      var myChart = echarts.init(chartDom, 'dark')\r\n      myChart.setOption(option)\r\n      myChart.on('mousedown', function (params) {\r\n        console.log('mousedown...', params)\r\n      })\r\n\r\n      // myChart.on('mousemove', function (params) {\r\n      //   console.log(\r\n      //     params,\r\n      //     'mousemove...',\r\n      //     params.event.event.offsetX,\r\n      //     params.event.event.offsetY\r\n      //   )\r\n      // })\r\n\r\n      myChart.on('mouseup', function (params) {\r\n        console.log('mouseup...')\r\n      })\r\n      console.log(myChart._chartsMap)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang='scss' scoped>\r\n.chart {\r\n  width: 100%;\r\n  height: 100%;\r\n}\r\n</style>\r\n\r\n\r\n\r\n\r\n\r\n"],"sourceRoot":"src/views/canvas"}]}