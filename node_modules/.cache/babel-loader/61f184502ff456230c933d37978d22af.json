GAAGA,EAAzB,CAAP;AACD","sourcesContent":["/**\n * 获取线条上的点\n * @param {Array} start 开始点位\n * @param {Array} end 结束点位\n * @param {Boolean} t 贝塞尔因子\n */\nexport function getLinePoint (start, end) {\n  return [(start[0] + end[0]) / 2, (start[1] + end[1]) / 2]\n}\n\n/**\n * 获取当前鼠标点到直线的距离\n * @param a 起点坐标\n * @param b 目标坐标\n * @param pointer 当前鼠标坐标\n */\nexport function getDistanceToLine (a, b, pointer) {\n  const [x1, y1] = a\n  const [x2, y2] = b\n  const [x3, y3] = pointer\n  const px = x2 - x1\n  const py = y2 - y1\n  const something = px * px + py * py\n  let u = ((x3 - x1) * px + (y3 - y1) * py) / something\n  if (u > 1) {\n    u = 1\n  } else if (u < 0) {\n    u = 0\n  }\n  const x = x1 + u * px\n  const y = y1 + u * py\n  const dx = x - x3\n  const dy = y - y3\n  return Math.sqrt(dx * dx + dy * dy)\n}\n"]}]}