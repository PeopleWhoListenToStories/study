{"remainingRequest":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/sulei/Desktop/study/demo/study/src/views/home/one/components/Xhandle.vue?vue&type=style&index=0&id=ab2b6854&lang=scss&scoped=true&","dependencies":[{"path":"/Users/sulei/Desktop/study/demo/study/src/views/home/one/components/Xhandle.vue","mtime":1613876003032},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/css-loader/dist/cjs.js","mtime":1608955430512},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1609483949117},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/postcss-loader/src/index.js","mtime":1608955430992},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/sass-loader/dist/cjs.js","mtime":1608955431082},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/cache-loader/dist/cjs.js","mtime":1611934239262},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/index.js","mtime":1609483949117}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Xhandle.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8EA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Xhandle.vue","sourceRoot":"src/views/home/one/components","sourcesContent":["<template>\r\n  <div ref=\"drag\" class=\"drag\">\r\n    <div ref=\"left\" :style=\"{ width: leftW }\">\r\n      <slot name=\"leftContext\"> </slot>\r\n    </div>\r\n    <div ref=\"line\" class=\"line\" @mousedown=\"mouseDown\"></div>\r\n    <div>\r\n      <slot name=\"rightContext\"> </slot>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  props: {\r\n    defaultWidths: {\r\n      type: Number,\r\n      default: 200,\r\n    },\r\n    visibleRange: {\r\n      type: Object,\r\n      default: () => {\r\n        return {\r\n          minWidth: 0,\r\n          maxWidth: 10000,\r\n        };\r\n      },\r\n    },\r\n  },\r\n  data() {\r\n    return {\r\n      leftW: null, // 默认左边容器的宽度\r\n      defaultWidth: null,\r\n      moveX: 0, // 移动的宽度\r\n      minWidth: null, // 限制最小宽度\r\n      maxWidth: null, // 限制最大宽度\r\n    };\r\n  },\r\n  created() {\r\n    document.addEventListener(\"mouseup\", this.mouseUp);\r\n    this.leftW = this.defaultWidths + \"px\";\r\n    this.defaultWidth = this.defaultWidths;\r\n    this.minWidth = this.visibleRange.minWidth;\r\n    this.maxWidth = this.visibleRange.maxWidth;\r\n  },\r\n  destroyed() {\r\n    document.removeEventListener(\"mouseup\", this.mouseUp);\r\n  },\r\n  methods: {\r\n    mouseDown(e) {\r\n      this.downX = e.pageX;\r\n      document.addEventListener(\"mousemove\", this.mouseMove);\r\n    },\r\n    mouseMove(e) {\r\n      e.preventDefault();\r\n      e.stopPropagation();\r\n      this.moveX = e.pageX - this.downX;\r\n      const moveWidth = this.defaultWidth + this.moveX;\r\n      if (moveWidth <= this.minWidth) {\r\n        this.leftW = this.minWidth + \"px\";\r\n      } else if (moveWidth >= this.maxWidth) {\r\n        this.leftW = this.maxWidth + \"px\";\r\n      } else {\r\n        this.leftW = moveWidth + \"px\";\r\n      }\r\n    },\r\n    mouseUp() {\r\n      document.removeEventListener(\"mousemove\", this.mouseMove);\r\n      this.defaultWidth = Number(\r\n        this.leftW.substring(0, this.leftW.length - 2)\r\n      );\r\n      // this.leftW = this.defaultWidth + \"px\";\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.drag {\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  border: 1px solid #ccc;\r\n}\r\n.left {\r\n  background: skyblue;\r\n}\r\n.line {\r\n  width: 2.5px;\r\n  background: orange;\r\n  height: 100%;\r\n  cursor: e-resize;\r\n}\r\n.line:hover {\r\n  background: gray;\r\n}\r\n.line:active {\r\n  background: black;\r\n}\r\n</style>\r\n"]}]}