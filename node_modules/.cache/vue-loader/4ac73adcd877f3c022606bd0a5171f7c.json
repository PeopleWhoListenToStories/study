{"remainingRequest":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/sulei/Desktop/study/demo/study/src/components/json-editor.vue?vue&type=style&index=0&id=61bc0712&lang=scss&scoped=true&","dependencies":[{"path":"/Users/sulei/Desktop/study/demo/study/src/components/json-editor.vue","mtime":1613876003005},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/css-loader/dist/cjs.js","mtime":1608955430512},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1609483949117},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/postcss-loader/src/index.js","mtime":1608955430992},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/sass-loader/dist/cjs.js","mtime":1608955431082},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/cache-loader/dist/cjs.js","mtime":1611934239262},{"path":"/Users/sulei/Desktop/study/demo/study/node_modules/vue-loader/lib/index.js","mtime":1609483949117}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["json-editor.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"json-editor.vue","sourceRoot":"src/components","sourcesContent":["<!--\r\n * @Author: your name\r\n * @Date: 2020-12-23 09:41:35\r\n * @LastEditTime: 2020-12-23 13:37:20\r\n * @LastEditors: Please set LastEditors\r\n * @Description: In User Settings Edit\r\n * @FilePath: \\app\\src\\components\\json-editor.vue\r\n-->\r\n\r\n<template>\r\n  <div class=\"json-editor\">\r\n    <textarea ref=\"textarea\" :value=\"value\"/>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport CodeMirror from 'codemirror'\r\nimport 'codemirror/addon/lint/lint.css'\r\nimport 'codemirror/lib/codemirror.css'\r\nimport 'codemirror/theme/rubyblue.css'\r\nrequire('script-loader!jsonlint')\r\nimport 'codemirror/mode/javascript/javascript'\r\nimport 'codemirror/addon/lint/lint'\r\nimport 'codemirror/addon/lint/json-lint'\r\nexport default {\r\n  name: 'JsonEditor',\r\n  /* eslint-disable vue/require-prop-types */\r\n  props: ['value'],\r\n  data() {\r\n    return {\r\n      jsonEditor: false\r\n    }\r\n  },\r\n  watch: {\r\n    value(value) {\r\n      const editorValue = this.jsonEditor.getValue()\r\n      if (value !== editorValue) {\r\n        this.jsonEditor.setValue(JSON.stringify(this.value, null, 2))\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.jsonEditor = CodeMirror.fromTextArea(this.$refs.textarea, {\r\n      lineNumbers: true,\r\n      mode: 'application/json',\r\n      gutters: ['CodeMirror-lint-markers'],\r\n      theme: 'rubyblue',\r\n      lint: true\r\n    })\r\n    this.jsonEditor.setValue(JSON.stringify(this.value, null, 2))\r\n    this.jsonEditor.on('change', cm => {\r\n      this.$emit('changed', cm.getValue())\r\n      this.$emit('input', cm.getValue())\r\n    })\r\n  },\r\n  methods: {\r\n    getValue() {\r\n      return this.jsonEditor.getValue()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.json-editor {\r\n  height: 100%;\r\n  position: relative;\r\n  ::v-deep {\r\n    .CodeMirror {\r\n      height: auto;\r\n      min-height: 300px;\r\n    }\r\n    .CodeMirror-scroll {\r\n      min-height: 300px;\r\n    }\r\n    .cm-s-rubyblue span.cm-string {\r\n      color: #F08047;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"]}]}