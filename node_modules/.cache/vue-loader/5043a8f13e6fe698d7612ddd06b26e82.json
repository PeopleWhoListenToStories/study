m :list=\"item.children\" :ruleForm=\"ruleForm[item.vModel]\" />\r\n      </template>\r\n    </el-form-item>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"EleForm\",\r\n  props: {\r\n    list: {\r\n      type: Array,\r\n      default: () => [],\r\n    },\r\n    ruleForm: {\r\n      type: Object,\r\n      default: () => {},\r\n    },\r\n  },\r\n  mounted() {\r\n    this.$forceUpdate();\r\n  },\r\n  methods: {\r\n    changeInput(e) {\r\n      console.log(e, \"eee\");\r\n    },\r\n    input() {\r\n      this.$forceUpdate();\r\n    },\r\n    add(form, type) {\r\n      console.log(form, type, \"==---==\");\r\n      this.$emit(\"addInput\", { form, type });\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.wrapper {\r\n  .label-name {\r\n    text-align: left;\r\n  }\r\n  /deep/ .m-1 {\r\n    margin-left: 10px;\r\n  }\r\n  /deep/ .m-2 {\r\n    margin-left: 20px;\r\n  }\r\n  /deep/ .m-3 {\r\n    margin-left: 30px;\r\n  }\r\n  /deep/ .m-4 {\r\n    margin-left: 40px;\r\n  }\r\n  /deep/ .m-5 {\r\n    margin-left: 50px;\r\n  }\r\n}\r\n</style>\r\n"]}]}